---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Map Your Video blog" } = Astro.props;
const fontBase = import.meta.env.BASE_URL;
const fontFaceCss = `
@font-face{font-family:"PP Neue Machina Inktrap";src:url("${fontBase}fonts/PPNeueMachina-InktrapRegular.woff2") format("woff2");font-style:normal;font-weight:400;font-display:swap;}
@font-face{font-family:"PP Neue Machina Inktrap";src:url("${fontBase}fonts/PPNeueMachina-InktrapRegularItalic.woff2") format("woff2");font-style:italic;font-weight:400;font-display:swap;}
@font-face{font-family:"PP Neue Machina Inktrap";src:url("${fontBase}fonts/PPNeueMachina-InktrapBold.woff2") format("woff2");font-style:normal;font-weight:700;font-display:swap;}
@font-face{font-family:"PP Neue Machina Inktrap";src:url("${fontBase}fonts/PPNeueMachina-InktrapBoldItalic.woff2") format("woff2");font-style:italic;font-weight:700;font-display:swap;}
`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global set:html={fontFaceCss}></style>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <slot />
  </body>
</html>
