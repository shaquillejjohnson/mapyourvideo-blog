---
import { SITE_ORIGIN } from "../config/site";

const blogHome = import.meta.env.BASE_URL;
---

<header class="border-b border-border bg-background">
  <div class="mx-auto flex max-w-[1600px] items-center justify-between px-6 py-5">
    <a href={SITE_ORIGIN} class="font-display text-lg tracking-tight text-primary hover:opacity-90">
      Map Your Video
    </a>
    <nav class="flex items-center gap-4">
      <a href={blogHome} class="font-display text-sm text-muted-foreground hover:text-foreground">Blog</a>
    </nav>
  </div>
</header>
