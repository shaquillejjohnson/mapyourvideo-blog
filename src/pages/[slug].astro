---
import BlogFooter from "../components/BlogFooter.astro";
import BlogHeader from "../components/BlogHeader.astro";
import BlogPostBody from "../components/BlogPostBody";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_ORIGIN } from "../config/site";
import { sanityClient, urlFor } from "../lib/sanity";
import { BLOG_POST_QUERY, BLOG_POSTS_QUERY } from "../lib/queries";

interface BlogPost {
  _id: string;
  title: string | null;
  slug: { current: string } | null;
  publishedAt: string | null;
  mainImage: unknown;
  excerpt: string | null;
  body: unknown[] | null;
  authorName?: string | null;
  cta?: { label: string; url: string } | null;
}

export async function getStaticPaths() {
  const posts = await sanityClient.fetch<{ _id: string; slug: { current: string } | null }[]>(
    BLOG_POSTS_QUERY,
  );

  return posts
    .filter((post) => post.slug?.current)
    .map((post) => ({
      params: { slug: post.slug!.current },
    }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing slug param.");
}

const post = await sanityClient.fetch<BlogPost | null>(BLOG_POST_QUERY, { slug });

if (!post) {
  return Astro.redirect(import.meta.env.BASE_URL);
}

const description =
  post.excerpt?.slice(0, 160) ||
  (post.title ? post.title + ". " : "") + "Map Your Video blog.";

function resolveCtaHref(url: string) {
  if (url.startsWith("#")) return url;
  if (url.startsWith("http")) return url;
  if (url.startsWith("/")) return `${SITE_ORIGIN}${url}`;
  return `${SITE_ORIGIN}${import.meta.env.BASE_URL}${url.replace(/^\.?\//, "")}`;
}
---

<BaseLayout title={`${post.title ?? "Untitled"} — Map Your Video`} description={description}>
  <BlogHeader />

  <article class="mx-auto max-w-[720px] px-6 py-12">
    <a href={import.meta.env.BASE_URL} class="font-body text-xs text-muted-foreground hover:text-foreground">
      ← Back to blog
    </a>

    <h1 class="mt-4 font-display text-3xl tracking-tight text-foreground">
      {post.title ?? "Untitled"}
    </h1>
    {post.authorName && (
      <p class="mt-2 font-body text-xs text-muted-foreground">{post.authorName}</p>
    )}

    {
      post.mainImage && (
        <div class="mt-6 overflow-hidden rounded-xl bg-muted">
          <img
            src={urlFor(post.mainImage as Parameters<typeof urlFor>[0]).width(720).fit("max").auto("format").url()}
            alt=""
            class="h-auto w-full object-contain"
          />
        </div>
      )
    }

    {
      post.body && post.body.length > 0 ? (
        <BlogPostBody body={post.body} />
      ) : (
        post.excerpt && (
          <p class="mt-6 font-body text-sm leading-relaxed text-foreground">{post.excerpt}</p>
        )
      )
    }

    {
      post.cta?.label && post.cta?.url && (
        <div class="mt-10">
          <a
            href={resolveCtaHref(post.cta.url)}
            class="inline-flex items-center justify-center rounded-lg bg-primary px-6 py-3 font-display text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90"
            target={post.cta.url.startsWith("http") ? "_blank" : undefined}
            rel={post.cta.url.startsWith("http") ? "noopener noreferrer" : undefined}
          >
            {post.cta.label}
          </a>
        </div>
      )
    }
  </article>

  <BlogFooter />
</BaseLayout>
