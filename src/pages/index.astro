---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sanityClient, urlFor } from "../lib/sanity";
import { BLOG_POSTS_QUERY } from "../lib/queries";

interface BlogPostListItem {
  _id: string;
  title: string | null;
  slug: { current: string } | null;
  publishedAt: string | null;
  mainImage: unknown;
  excerpt: string | null;
}

const posts = await sanityClient.fetch<BlogPostListItem[]>(BLOG_POSTS_QUERY);
---

<BaseLayout
  title="Blog - Map Your Video"
  description="Short posts for creators who get stuck before they film."
>
  <header class="mb-10">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">The Blog</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight">Map Your Video</h1>
  </header>

  {
    posts.length === 0 ? (
      <p class="text-zinc-500">No posts yet.</p>
    ) : (
      <ul class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <li>
            <a
              href={`/${post.slug?.current ?? post._id}/`}
              class="group block overflow-hidden rounded-xl border border-zinc-200 bg-white transition hover:border-zinc-400"
            >
              {post.mainImage && (
                <img
                  src={urlFor(post.mainImage as Parameters<typeof urlFor>[0])
                    .width(1000)
                    .height(600)
                    .fit("crop")
                    .auto("format")
                    .url()}
                  alt={post.title ?? "Blog post cover"}
                  class="aspect-[4/3] w-full object-cover transition-transform group-hover:scale-[1.02]"
                  loading="lazy"
                />
              )}
              <div class="p-5">
                <h2 class="text-lg font-semibold">{post.title ?? "Untitled"}</h2>
                {post.excerpt && <p class="mt-2 line-clamp-3 text-sm text-zinc-600">{post.excerpt}</p>}
              </div>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
